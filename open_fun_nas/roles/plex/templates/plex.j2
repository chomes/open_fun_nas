---
version: '2'
services:
  plex:
    container_name: plex
    image: plexinc/pms-docker
    restart: unless-stopped
    environment:
      - TZ={{ time_zone }}
      - PLEX_CLAIM={{ plex_claim_key }}
    network_mode: host
    volumes:
      - {{ storage_dir }}/server/database:/config
      - {{ storage_dir }}/server/transcode/temp:/transcode
      - {{ storage_dir }}/media:/data